generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LISTENER
  USER
}

enum ListenerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ChatMode {
  AI
  PEER
  AUTO
}

enum SessionStatus {
  WAITING
  ACTIVE
  AI_ACTIVE
  ENDED
  CANCELLED
  EXPIRED
  FLAGGED
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum ReportCategory {
  ABUSIVE_BEHAVIOR
  UNSAFE_ADVICE
  INAPPROPRIATE_LISTENER
  INAPPROPRIATE_USER
  TECHNICAL_ISSUE
  MODERATION_FAILURE
  OTHER
}

enum ReportStatus {
  OPEN
  RESOLVED
}

model User {
  id                     String           @id @default(cuid())
  fullName               String
  email                  String           @unique
  passwordHash           String
  role                   Role             @default(USER)
  listenerStatus         ListenerStatus?
  language               String?
  specialty              String?
  anonymousAlias         String?          @unique
  isAvailable            Boolean          @default(false)
  isActive               Boolean          @default(true)
  suspendedAt            DateTime?
  suspendedReason        String?
  passwordResetToken     String?          @unique
  passwordResetExpiresAt DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  sentMessages      Message[]        @relation("SentMessages")
  listenerSessions  ChatSession[]    @relation("ListenerSessions")
  userSessions      ChatSession[]    @relation("UserSessions")
  submittedReports  Report[]         @relation("SubmittedReports")
  receivedReports   Report[]         @relation("ReportedAgainst")
  feedbackGiven     Feedback[]       @relation("FeedbackGivenBy")
}

model ChatSession {
  id                   String         @id @default(cuid())
  topic                String
  mode                 ChatMode       @default(AUTO)
  status               SessionStatus  @default(WAITING)
  selectedDurationMin  Int
  startedAt            DateTime       @default(now())
  endedAt              DateTime?
  expiresAt            DateTime?
  userId               String
  listenerId           String?
  riskLevel            RiskLevel      @default(NONE)
  riskReason           String?
  flaggedCount         Int            @default(0)
  highRiskDetected     Boolean        @default(false)
  emergencyNoticeSent  Boolean        @default(false)
  chatRetentionCleared Boolean        @default(false)

  user     User   @relation("UserSessions", fields: [userId], references: [id])
  listener User?  @relation("ListenerSessions", fields: [listenerId], references: [id])
  messages Message[]
  reports  Report[]
  feedback Feedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([listenerId])
  @@index([status])
  @@index([riskLevel])
}

model Message {
  id             String    @id @default(cuid())
  sessionId      String
  senderId       String
  text           String
  maskedText     String?
  blocked        Boolean   @default(false)
  moderationMeta Json?
  riskLevel      RiskLevel @default(NONE)
  createdAt      DateTime  @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender  User        @relation("SentMessages", fields: [senderId], references: [id])

  @@index([sessionId])
  @@index([senderId])
  @@index([riskLevel])
}

model Report {
  id             String         @id @default(cuid())
  sessionId      String?
  reporterId     String
  reportedUserId String?
  category       ReportCategory
  status         ReportStatus   @default(OPEN)
  description    String
  adminNote      String?
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime       @default(now())

  session      ChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  reporter     User         @relation("SubmittedReports", fields: [reporterId], references: [id])
  reportedUser User?        @relation("ReportedAgainst", fields: [reportedUserId], references: [id])

  @@index([sessionId])
  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
}

model Feedback {
  id            String    @id @default(cuid())
  sessionId     String
  submittedById String
  rating        Int
  comment       String?
  wouldUseAgain Boolean?
  createdAt     DateTime  @default(now())

  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  submittedBy User        @relation("FeedbackGivenBy", fields: [submittedById], references: [id])

  @@index([sessionId])
  @@index([submittedById])
}