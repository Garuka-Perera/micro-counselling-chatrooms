generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  fullName         String
  email            String          @unique
  passwordHash     String
  role             Role            @default(USER)
  listenerStatus   ListenerStatus?
  language         String?
  specialty        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  anonymousAlias   String?         @unique
  isAvailable      Boolean         @default(false)
  listenerSessions ChatSession[]   @relation("ListenerSessions")
  userSessions     ChatSession[]   @relation("UserSessions")
  feedbackGiven    Feedback[]      @relation("FeedbackGivenBy")
  sentMessages     Message[]       @relation("SentMessages")
  receivedReports  Report[]        @relation("ReportedAgainst")
  submittedReports Report[]        @relation("SubmittedReports")
}

model ChatSession {
  id                   String        @id @default(cuid())
  topic                String
  startedAt            DateTime      @default(now())
  endedAt              DateTime?
  userId               String
  listenerId           String?
  chatRetentionCleared Boolean       @default(false)
  createdAt            DateTime      @default(now())
  emergencyNoticeSent  Boolean       @default(false)
  expiresAt            DateTime?
  flaggedCount         Int           @default(0)
  highRiskDetected     Boolean       @default(false)
  mode                 ChatMode      @default(AUTO)
  riskLevel            RiskLevel     @default(NONE)
  riskReason           String?
  selectedDurationMin  Int
  updatedAt            DateTime      @updatedAt
  status               SessionStatus @default(WAITING)
  listener             User?         @relation("ListenerSessions", fields: [listenerId], references: [id])
  user                 User          @relation("UserSessions", fields: [userId], references: [id])
  feedback             Feedback[]
  messages             Message[]
  reports              Report[]

  @@index([userId])
  @@index([listenerId])
  @@index([status])
  @@index([riskLevel])
}

model Message {
  id             String      @id @default(cuid())
  sessionId      String
  senderId       String
  text           String
  maskedText     String?
  blocked        Boolean     @default(false)
  moderationMeta Json?
  createdAt      DateTime    @default(now())
  riskLevel      RiskLevel   @default(NONE)
  sender         User        @relation("SentMessages", fields: [senderId], references: [id])
  session        ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([senderId])
  @@index([riskLevel])
}

model Report {
  id             String         @id @default(cuid())
  sessionId      String?
  reporterId     String
  reportedUserId String?
  category       ReportCategory
  description    String
  createdAt      DateTime       @default(now())
  reportedUser   User?          @relation("ReportedAgainst", fields: [reportedUserId], references: [id])
  reporter       User           @relation("SubmittedReports", fields: [reporterId], references: [id])
  session        ChatSession?   @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([reporterId])
  @@index([reportedUserId])
}

model Feedback {
  id            String      @id @default(cuid())
  sessionId     String
  submittedById String
  rating        Int
  comment       String?
  wouldUseAgain Boolean?
  createdAt     DateTime    @default(now())
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  submittedBy   User        @relation("FeedbackGivenBy", fields: [submittedById], references: [id])

  @@index([sessionId])
  @@index([submittedById])
}

enum Role {
  ADMIN
  LISTENER
  USER
}

enum ListenerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChatMode {
  AI
  PEER
  AUTO
}

enum SessionStatus {
  WAITING
  ACTIVE
  AI_ACTIVE
  ENDED
  CANCELLED
  EXPIRED
  FLAGGED
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum ReportCategory {
  ABUSIVE_BEHAVIOR
  UNSAFE_ADVICE
  INAPPROPRIATE_LISTENER
  INAPPROPRIATE_USER
  TECHNICAL_ISSUE
  MODERATION_FAILURE
  OTHER
}
